# Web
VITE_API_BASE_URL=http://localhost:3001/api

# API
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/humian_chongya
JWT_SECRET=replace-with-a-long-random-secret
PORT=3001
UPLOAD_DRIVER=local
UPLOAD_ROOT=uploads
PUBLIC_ASSET_BASE_URL=

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ASR: Bailian/DashScope qwen3-asr-flash. This works with local Base64 audio from the review processing page.
ASR_PROVIDER=qwen3-asr-flash
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_ASR_MODEL=qwen3-asr-flash

# ASR fallback: Aliyun Intelligent Speech Interaction - File Transcription.
# This requires a public audio URL, usually from OSS.
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_NLS_APP_KEY=
ALIYUN_NLS_ENDPOINT=http://filetrans.cn-shanghai.aliyuncs.com
ALIYUN_NLS_TIMEOUT_MS=180000
ALIYUN_NLS_POLL_INTERVAL_MS=10000

# OSS placeholder for later
OSS_REGION=
OSS_BUCKET=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
